generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id               String   @id @default(uuid())
  external_id      String   @unique
  nome             String
  marca            String?
  categoria        String
  subcategoria     String?
  classificacao    String   @default("Unissex")
  notas_olfativas  String?
  familia_olfativa String?
  projecao         String?
  fixacao          String?
  ocasiao          String?
  descricao        String?
  imagem_url       String?
  preco_custo      Float?
  preco_venda      Float
  estoque          Int      @default(0)
  disponivel       Boolean  @default(true)
  origem           String   @default("SCRAPER")
  updated_at       DateTime @updatedAt
  publicar_no_site Boolean  @default(false)
  is_promocao      Boolean  @default(false)
  
  @@index([categoria])
  @@index([publicar_no_site])
}
